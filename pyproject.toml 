[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "DIHC-FeatureManager"
version = "0.13.0"
description = "Signal segmentation and physiological signal feature extraction tools"
readme = "README.md"
requires-python = ">=3.10,<3.14"
authors = [
    { name = "WWM Emran" }
]
dependencies = [
    "numpy",
    "pandas",
    "scipy",
    "matplotlib",
    "scikit-learn",
    "tqdm",
    "antropy",
    "mne",
    "numba",
]

[tool.setuptools.packages.find]
where = ["."]
include = ["DIHC_FeatureManager*"]